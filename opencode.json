{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "allow",
    "webfetch": "ask",
    "bash": {
      "*": "allow",

      "*--force*": "deny",
      "*--force-with-lease*": "deny",
      "*rm -rf*": "deny",
      "*rm -fr*": "deny",
      "git push": "deny",
      "git push *": "deny",
      "*git push*": "deny",

      "git commit*": "allow",
      "dotnet *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add*": "allow",
      "git checkout*": "ask",
      "git reset*": "ask",
      "git clean*": "ask"
    }
  }
}
