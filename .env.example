# Recall Commander AI configuration template.
#
# Copy this file to `.env` in the directory where you run `rc` and fill in
# what you need. The real `.env` is gitignored — never commit API keys.
#
# Format: KEY=VALUE, `#` comments, `__` separates configuration sections.
# `.env` values override appsettings.json and user secrets.

# Which evaluator reviews your answers: fake | ollama | gemini.
# "fake" is the default and needs nothing else — no network, no keys.
Ai__Provider=fake

# --- Ollama (local, no API key) ------------------------------------------
# Requires a running Ollama server (`ollama serve`) with the model pulled.

#Ai__Ollama__Endpoint=http://localhost:11434
#Ai__Ollama__Model=llama3.2

# --- Gemini (Google AI REST API) -----------------------------------------
# Get an API key from Google AI Studio. Keep it in this file or in user
# secrets (`dotnet user-secrets set Ai:Gemini:ApiKey <key>`), never in
# committed files.

#Ai__Gemini__Model=gemini-2.0-flash
#Ai__Gemini__ApiKey=your-api-key-here
